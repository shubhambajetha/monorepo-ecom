generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  admin
}

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String?
  email     String   @unique
  password  String
  role      Role     @default(customer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
